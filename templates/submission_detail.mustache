{{!
    @template mod_confsubmissions/submission_detail

    Read-only detail view of a single submission.

    Context variables required for this template:
    * see classes/output/submission_detail.php

    Example context (json):
    {
        "title": "My great talk",
        "abstract": "This talk is about...",
        "trackpill": "<span class=\"mod_confsubmissions-track-pill\">Track A</span>",
        "status": "Submitted",
        "timecreated": "1 January 2026, 9:00 AM",
        "timemodified": "1 January 2026, 9:00 AM",
        "speakers": [
            {"name": "Jane Doe", "email": "jane@example.com", "isprimary": true}
        ],
        "hasfields": true,
        "fields": [
            {"label": "Presentation language", "value": "English"}
        ],
        "canedit": true,
        "editurl": "#"
    }
}}
<div class="mod_confsubmissions-submission-detail">
    <dl class="row">
        <dt class="col-sm-3">{{#str}}title, mod_confsubmissions{{/str}}</dt>
        {{! "title" is pre-escaped by format_string() in submission_detail::export_for_template(),
            so it is safe -- and, per that method's own comment, REQUIRED -- to output unescaped
            here, exactly like "abstract" below; double-mustache output here previously
            double-escaped '&' into '&amp;amp;'. }}
        <dd class="col-sm-9">{{{title}}}</dd>

        <dt class="col-sm-3">{{#str}}track, mod_confsubmissions{{/str}}</dt>
        {{! "trackpill" is trusted HTML (a coloured pill <span>, or an already-escaped "No track"
            string) built by submission_detail::get_track_pill_html() -- see that method's own
            comment for why it must be output unescaped here. }}
        <dd class="col-sm-9">{{{trackpill}}}</dd>

        <dt class="col-sm-3">{{#str}}status, mod_confsubmissions{{/str}}</dt>
        <dd class="col-sm-9">{{status}}</dd>

        <dt class="col-sm-3">{{#str}}submitted, mod_confsubmissions{{/str}}</dt>
        <dd class="col-sm-9">{{timecreated}}</dd>

        <dt class="col-sm-3">{{#str}}lastmodified, mod_confsubmissions{{/str}}</dt>
        <dd class="col-sm-9">{{timemodified}}</dd>

        <dt class="col-sm-3">{{#str}}abstract, mod_confsubmissions{{/str}}</dt>
        {{! "abstract" is pre-escaped with s() then nl2br()'d in submission_detail::export_for_template(), so it is safe to output unescaped here. }}
        <dd class="col-sm-9">{{{abstract}}}</dd>

        <dt class="col-sm-3">{{#str}}speakers, mod_confsubmissions{{/str}}</dt>
        <dd class="col-sm-9">
            <ul class="list-unstyled mb-0">
                {{#speakers}}
                <li>
                    {{name}}
                    {{#email}}&lt;{{email}}&gt;{{/email}}
                    {{#isprimary}}<span class="badge badge-secondary">{{#str}}primaryspeaker, mod_confsubmissions{{/str}}</span>{{/isprimary}}
                </li>
                {{/speakers}}
            </ul>
        </dd>

        {{#hasfields}}
        {{#fields}}
        <dt class="col-sm-3">{{label}}</dt>
        <dd class="col-sm-9">{{value}}</dd>
        {{/fields}}
        {{/hasfields}}
    </dl>

    {{#canedit}}
    <a href="{{editurl}}" class="btn btn-secondary">{{#str}}editsubmission, mod_confsubmissions{{/str}}</a>
    {{/canedit}}
</div>
